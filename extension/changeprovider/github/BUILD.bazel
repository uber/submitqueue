load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "github",
    srcs = [
        "config.go",
        "convert.go",
        "graphql.go",
        "provider.go",
        "validate.go",
    ],
    importpath = "github.com/uber/submitqueue/extension/changeprovider/github",
